<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Gerencial - DomoNow</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <style>
        /* ESTILOS BASE ORIGINALES */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary-color: #1F4788;
            --primary-light: #2E75B6;
            --accent-color: #0B5E8F;
            --success-color: #06A77D;
            --warning-color: #F7C616;
            --danger-color: #E85D4F;
            --info-color: #3B82F6;
            --okr-color: #8B5CF6;
            --kpi-color: #06A77D;
            --bg-light: #F8F9FA;
            --bg-card: #FFFFFF;
            --border-color: #E8EAF0;
            --text-primary: #1A1A1A;
            --text-secondary: #6B7280;
            --text-tertiary: #9CA3AF;
        }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif; background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%); color: var(--text-primary); line-height: 1.6; min-height: 100vh; }
        .dashboard-wrapper { display: flex; min-height: 100vh; }
        
        /* Sidebar Original */
        .sidebar { width: 260px; background: var(--primary-color); color: white; padding: 24px; box-shadow: 2px 0 12px rgba(0,0,0,0.08); position: fixed; height: 100vh; overflow-y: auto; z-index: 100; }
        .logo { font-size: 20px; font-weight: 700; margin-bottom: 32px; display: flex; align-items: center; gap: 10px; }
        .nav-menu { list-style: none; }
        .nav-item { margin-bottom: 8px; }
        .nav-link { display: flex; align-items: center; gap: 12px; padding: 12px 16px; color: rgba(255,255,255,0.8); text-decoration: none; border-radius: 8px; cursor: pointer; transition: all 300ms; border: 2px solid transparent; font-size: 14px; font-weight: 500; }
        .nav-link:hover { background: rgba(255,255,255,0.15); color: white; }
        .nav-link.active { background: rgba(255,255,255,0.25); color: white; border-color: rgba(255,255,255,0.5); }
        
        /* Main Content Original */
        .main-content { margin-left: 260px; flex: 1; padding: 32px; overflow-y: auto; }
        .header-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; background: var(--bg-card); padding: 20px 24px; border-radius: 12px; border: 1px solid var(--border-color); box-shadow: 0 2px 8px rgba(0,0,0,0.04); flex-wrap: wrap; gap: 16px; }
        .header-title { font-size: 28px; font-weight: 700; color: var(--primary-color); }
        .header-actions { display: flex; gap: 12px; align-items: center; }
        
        /* Botones Originales */
        .action-btn { padding: 10px 18px; border: none; background: var(--primary-color); color: white; border-radius: 6px; cursor: pointer; font-size: 13px; font-weight: 600; transition: all 200ms; display: flex; align-items: center; gap: 8px; }
        .action-btn:hover { background: var(--accent-color); transform: translateY(-2px); }
        .action-btn.success { background: var(--success-color); }
        .action-btn.info { background: var(--info-color); } /* Nuevo estilo para colaboradores */

        /* Estilos de Secciones y Filtros Originales */
        .section { display: none; }
        .section.active { display: block; animation: fadeIn 300ms ease-in; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .filters-row { display: flex; gap: 12px; margin-bottom: 24px; flex-wrap: wrap; align-items: center; }
        .filter-group { display: flex; gap: 8px; flex-wrap: wrap; }
        .filter-btn { padding: 8px 14px; border: 1px solid var(--border-color); background: var(--bg-card); border-radius: 6px; cursor: pointer; font-size: 12px; font-weight: 600; transition: all 200ms; color: var(--text-secondary); }
        .filter-btn:hover { border-color: var(--primary-light); background: var(--bg-light); }
        .filter-btn.active { background: var(--primary-color); color: white; border-color: var(--primary-color); }

        /* Estilos de Tarjetas Originales */
        .indicator-card { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 10px; padding: 18px; margin-bottom: 16px; transition: all 300ms; }
        .indicator-card:hover { border-color: var(--primary-light); box-shadow: 0 4px 12px rgba(31, 71, 136, 0.1); }
        .indicator-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
        .indicator-badges { display: flex; gap: 8px; flex-wrap: wrap; }
        .badge { display: inline-block; padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
        .badge.okr { background: rgba(139, 92, 246, 0.15); color: var(--okr-color); }
        .badge.kpi { background: rgba(6, 167, 125, 0.15); color: var(--kpi-color); }
        .badge.period { background: rgba(59, 130, 246, 0.15); color: var(--info-color); }
        .indicator-title { font-size: 15px; font-weight: 600; color: var(--text-primary); margin: 8px 0; }
        .indicator-meta { font-size: 12px; color: var(--text-secondary); margin-bottom: 12px; }
        .progress-bar { width: 100%; height: 8px; background: var(--bg-light); border-radius: 4px; overflow: hidden; margin: 12px 0; }
        .progress-fill { height: 100%; border-radius: 4px; transition: width 500ms ease-out; }
        .progress-text { font-size: 11px; color: var(--text-secondary); margin-bottom: 12px; }
        .indicator-actions { display: flex; gap: 8px; margin-top: 12px; flex-wrap: wrap; padding-top: 12px; border-top: 1px solid var(--border-color); }
        .btn-small { padding: 7px 12px; border: none; border-radius: 5px; cursor: pointer; font-size: 12px; font-weight: 600; transition: all 200ms; display: flex; align-items: center; gap: 6px; }
        .btn-edit { background: var(--info-color); color: white; }
        .btn-edit:hover { background: #2563EB; }
        .btn-action { background: var(--success-color); color: white; }
        .btn-action:hover { background: #059669; }

        /* NUEVOS ESTILOS PARA COLABORADORES INDIVIDUALES EN KPI */
        .kpi-collabs-section { margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border-color); background-color: #fbfcfd; border-radius: 8px; padding: 12px; }
        .kpi-collabs-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
        .kpi-collabs-title { font-size: 13px; font-weight: 700; color: var(--text-primary); display: flex; align-items: center; gap: 6px; }
        .collab-individual-card { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 8px; padding: 10px; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center; font-size: 12px; transition: all 200ms; }
        .collab-individual-card:hover { border-color: var(--primary-light); background-color: #f4f7fa; }
        .collab-indiv-info { flex: 1; }
        .collab-indiv-name { font-weight: 600; color: var(--text-primary); margin-bottom: 2px; }
        .collab-indiv-meta { color: var(--text-secondary); }
        .collab-indiv-performance { text-align: right; margin-left: 15px; display: flex; align-items: center; gap: 8px; }
        .collab-indiv-pct { font-weight: 700; font-size: 14px; color: var(--primary-color); }
        .btn-icon { background: none; border: none; cursor: pointer; padding: 4px; color: var(--text-tertiary); transition: color 200ms; border-radius: 4px; }
        .btn-icon:hover { color: var(--primary-color); background-color: rgba(31, 71, 136, 0.1); }
        .btn-icon.delete:hover { color: var(--danger-color); background-color: rgba(232, 93, 79, 0.1); }

        /* ESTILOS PARA SECCIÓN DE ACCIONES */
        .actions-section { margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border-color); background-color: #fef9f3; border-radius: 8px; padding: 12px; }
        .actions-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
        .actions-title { font-size: 13px; font-weight: 700; color: var(--text-primary); display: flex; align-items: center; gap: 6px; }
        .action-item-card { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 8px; padding: 10px; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: flex-start; font-size: 12px; transition: all 200ms; }
        .action-item-card:hover { border-color: var(--primary-light); background-color: #fffaf5; }
        .action-item-info { flex: 1; }
        .action-item-title { font-weight: 600; color: var(--text-primary); margin-bottom: 4px; }
        .action-item-meta { color: var(--text-secondary); font-size: 11px; margin-bottom: 2px; }
        .action-item-responsible { color: var(--info-color); font-weight: 500; font-size: 11px; display: flex; align-items: center; gap: 4px; }
        .action-item-actions { display: flex; gap: 4px; flex-direction: column; }
        .btn-icon-action { background: none; border: none; cursor: pointer; padding: 4px 6px; color: var(--text-tertiary); transition: color 200ms; border-radius: 4px; font-size: 12px; display: flex; align-items: center; gap: 4px; white-space: nowrap; }
        .btn-icon-action:hover { color: var(--primary-color); background-color: rgba(31, 71, 136, 0.1); }
        .btn-icon-action.delete:hover { color: var(--danger-color); background-color: rgba(232, 93, 79, 0.1); }

        /* Estilos de Modales Originales Actualizados */
        .modal { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center; padding: 20px; overflow-y: auto; }
        .modal.active { display: flex; }
        .modal-content { background: var(--bg-card); border-radius: 12px; padding: 32px; max-width: 650px; width: 100%; max-height: 90vh; overflow-y: auto; box-shadow: 0 20px 60px rgba(0,0,0,0.3); margin: auto; position: relative;}
        .modal-header { font-size: 20px; font-weight: 700; color: var(--primary-color); margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; }
        .modal-close { background: none; border: none; font-size: 28px; cursor: pointer; color: var(--text-secondary); padding: 0; position: absolute; top: 20px; right: 20px; }
        
        /* Formularios Originales */
        .form-group { margin-bottom: 20px; }
        .form-group label { font-size: 13px; font-weight: 600; color: var(--text-primary); display: block; margin-bottom: 8px; }
        .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 10px 12px; border: 1px solid var(--border-color); border-radius: 6px; font-size: 13px; font-family: inherit; }
        .form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline: none; border-color: var(--primary-color); box-shadow: 0 0 0 3px rgba(31, 71, 136, 0.1); }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .form-actions { display: flex; gap: 12px; justify-content: flex-end; margin-top: 28px; padding-top: 20px; border-top: 1px solid var(--border-color); }
        .form-actions button { padding: 10px 20px; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; }
        .btn-cancel { background: var(--bg-light); color: var(--text-primary); }
        .btn-submit { background: var(--primary-color); color: white; }
        .btn-delete-modal { background: var(--danger-color); color: white; margin-right: auto; }

        /* Selectores Especiales Originales */
        .type-selector, .period-selector { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 20px; }
        .type-option { padding: 12px; border: 2px solid var(--border-color); border-radius: 8px; cursor: pointer; text-align: center; font-weight: 600; font-size: 12px; background: var(--bg-light); transition: all 200ms; color: var(--text-secondary); }
        .type-option:hover { border-color: var(--primary-color); color: var(--primary-color); }
        .type-option.selected { border-color: var(--success-color); background: rgba(6, 167, 125, 0.1); color: var(--success-color); }

        /* Otros Originales */
        .alert { padding: 16px; border-radius: 8px; border-left: 4px solid; margin-bottom: 16px; font-size: 14px; }
        .alert.info { background: rgba(31, 71, 136, 0.1); border-color: var(--primary-color); color: var(--primary-color); }
        .empty-state { text-align: center; padding: 48px 20px; color: var(--text-tertiary); font-size: 14px; }
        
        /* Lista Maestra Colaboradores */
        .master-collab-list { margin-top: 15px; max-height: 200px; overflow-y: auto; border: 1px solid var(--border-color); border-radius: 8px; }
        .master-collab-item { display: flex; justify-content: space-between; align-items: center; padding: 10px 15px; border-bottom: 1px solid var(--border-color); font-size: 13px; }
        .master-collab-item:last-child { border-bottom: none; }

        /* Scrollbar Original */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: var(--bg-light); }
        ::-webkit-scrollbar-thumb { background: var(--border-color); border-radius: 4px; }
    </style>
</head>
<body>
    <div class="dashboard-wrapper">
        <aside class="sidebar">
            <div class="logo">
                <span style="font-size: 28px;">📊</span>
                <span>DomoNow</span>
            </div>
            <ul class="nav-menu">
                <li class="nav-item"><a href="#" class="nav-link active" data-section="home"><span style="font-size: 18px;">🏠</span><span>Dashboard</span></a></li>
                <li class="nav-item"><a href="#" class="nav-link" data-section="okrs"><span style="font-size: 18px;">🎯</span><span>OKRs</span></a></li>
                <li class="nav-item"><a href="#" class="nav-link" data-section="kpis"><span style="font-size: 18px;">📈</span><span>KPIs</span></a></li>
                <li class="nav-item"><a href="#" class="nav-link" data-section="acciones"><span style="font-size: 18px;">⚡</span><span>Acciones</span></a></li>
            </ul>
            <div style="position: absolute; bottom: 24px; left: 24px; right: 24px;">
                <div style="display: flex; align-items: center; gap: 12px;">
                    <div style="width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,0.3); display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 14px;">MC</div>
                    <div style="color: rgba(255,255,255,0.9); font-size: 12px;">
                        <div style="font-weight: 600;">Marco Carrasquilla</div>
                        <div style="opacity: 0.8;">CEO</div>
                    </div>
                </div>
            </div>
        </aside>

        <main class="main-content">
            <div class="header-bar">
                <div class="header-title" id="pageTitle">📊 Dashboard por Área</div>
                <div class="header-actions">
                    <button class="action-btn info" id="manageCollabsBtn">👥 Colaboradores</button>
                    <button class="action-btn success" id="addBtn">➕ Crear Indicador</button>
                </div>
            </div>

            <div class="alert info">
                <strong>📊 Gestión de Indicadores</strong> - Crea, edita y monitorea tus OKRs y KPIs por área y periodicidad. Asigna metas individuales en KPIs.
            </div>

            <section id="home" class="section active">
                <div class="filters-row">
                    <strong style="width: 100%; color: var(--text-primary); margin-bottom: 8px; font-size: 14px;">Filtrar por Área:</strong>
                    <div class="filter-group">
                        <button class="filter-btn active" data-filter="area" data-value="all">📊 Todas</button>
                        <button class="filter-btn" data-filter="area" data-value="fabrica">🏭 Fábrica</button>
                        <button class="filter-btn" data-filter="area" data-value="marketing">📱 Marketing</button>
                        <button class="filter-btn" data-filter="area" data-value="comercial">💼 Comercial</button>
                        <button class="filter-btn" data-filter="area" data-value="servicio">🔧 Servicio</button>
                    </div>
                </div>
                <div class="filters-row">
                    <strong style="width: 100%; color: var(--text-primary); margin-bottom: 8px; font-size: 14px;">Filtrar por Periodicidad:</strong>
                    <div class="filter-group">
                        <button class="filter-btn active" data-filter="period" data-value="all">📅 Todos</button>
                        <button class="filter-btn" data-filter="period" data-value="semanal">📆 Semanal</button>
                        <button class="filter-btn" data-filter="period" data-value="quincenal">📋 Quincenal</button>
                        <button class="filter-btn" data-filter="period" data-value="mensual">📊 Mensual</button>
                    </div>
                </div>
                <div id="homeContent"></div>
            </section>

            <section id="okrs" class="section">
                <h2 style="margin-bottom: 20px; color: var(--primary-color); font-size: 18px;">🎯 Objetivos y Resultados Clave (OKRs)</h2>
                <div class="filters-row">
                    <strong style="width: 100%; color: var(--text-primary); margin-bottom: 8px; font-size: 14px;">Filtrar por Área:</strong>
                    <div class="filter-group">
                        <button class="filter-btn active okr-area-filter" data-value="all">📊 Todas</button>
                        <button class="filter-btn okr-area-filter" data-value="fabrica">🏭 Fábrica</button>
                        <button class="filter-btn okr-area-filter" data-value="marketing">📱 Marketing</button>
                        <button class="filter-btn okr-area-filter" data-value="comercial">💼 Comercial</button>
                        <button class="filter-btn okr-area-filter" data-value="servicio">🔧 Servicio</button>
                    </div>
                </div>
                <div class="filters-row">
                    <strong style="width: 100%; color: var(--text-primary); margin-bottom: 8px; font-size: 14px;">Filtrar por Periodicidad:</strong>
                    <div class="filter-group">
                        <button class="filter-btn active okr-period-filter" data-value="all">📅 Todos</button>
                        <button class="filter-btn okr-period-filter" data-value="semanal">📆 Semanal</button>
                        <button class="filter-btn okr-period-filter" data-value="quincenal">📋 Quincenal</button>
                        <button class="filter-btn okr-period-filter" data-value="mensual">📊 Mensual</button>
                    </div>
                </div>
                <div id="okrsContent"></div>
            </section>

            <section id="kpis" class="section">
                <h2 style="margin-bottom: 20px; color: var(--primary-color); font-size: 18px;">📈 Indicadores Clave de Rendimiento (KPIs)</h2>
                <div class="filters-row">
                    <strong style="width: 100%; color: var(--text-primary); margin-bottom: 8px; font-size: 14px;">Filtrar por Área:</strong>
                    <div class="filter-group">
                        <button class="filter-btn active kpi-area-filter" data-value="all">📊 Todas</button>
                        <button class="filter-btn kpi-area-filter" data-value="fabrica">🏭 Fábrica</button>
                        <button class="filter-btn kpi-area-filter" data-value="marketing">📱 Marketing</button>
                        <button class="filter-btn kpi-area-filter" data-value="comercial">💼 Comercial</button>
                        <button class="filter-btn kpi-area-filter" data-value="servicio">🔧 Servicio</button>
                    </div>
                </div>
                <div class="filters-row">
                    <strong style="width: 100%; color: var(--text-primary); margin-bottom: 8px; font-size: 14px;">Filtrar por Periodicidad:</strong>
                    <div class="filter-group">
                        <button class="filter-btn active kpi-period-filter" data-value="all">📅 Todos</button>
                        <button class="filter-btn kpi-period-filter" data-value="semanal">📆 Semanal</button>
                        <button class="filter-btn kpi-period-filter" data-value="quincenal">📋 Quincenal</button>
                        <button class="filter-btn kpi-period-filter" data-value="mensual">📊 Mensual</button>
                    </div>
                </div>
                <div id="kpisContent"></div>
            </section>

            <section id="acciones" class="section">
                <h2 style="margin-bottom: 20px; color: var(--primary-color); font-size: 18px;">⚡ Seguimiento de Acciones</h2>
                <div id="accionesContent"></div>
            </section>
        </main>
    </div>

    <div id="indicatorModal" class="modal">
        <div class="modal-content">
            <button class="modal-close">&times;</button>
            <div class="modal-header">
                <span id="modalTitle">Crear Nuevo Indicador</span>
            </div>
            <form id="indicatorForm">
                <div class="form-group">
                    <label>Tipo de Indicador *</label>
                    <div class="type-selector">
                        <div class="type-option" data-type="okr">🎯 OKR</div>
                        <div class="type-option" data-type="kpi">📈 KPI</div>
                    </div>
                    <input type="hidden" id="indicatorType" required />
                </div>
                <div class="form-group"><label>Nombre *</label><input type="text" id="indicatorName" required /></div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Área *</label>
                        <select id="indicatorArea" required>
                            <option value="">-- Seleccionar --</option>
                            <option value="fabrica">🏭 Fábrica</option>
                            <option value="marketing">📱 Marketing</option>
                            <option value="comercial">💼 Comercial</option>
                            <option value="servicio">🔧 Servicio</option>
                        </select>
                    </div>
                    <div class="form-group"><label>Meta *</label><input type="number" step="0.1" id="indicatorTarget" required /></div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Unidad *</label>
                        <select id="indicatorUnit" required>
                            <option value="">-- Seleccionar --</option>
                            <option>% (Porcentaje)</option><option>Días</option><option>Cantidad</option><option>Horas</option><option>/10 (Puntuación)</option><option>USD</option>
                        </select>
                    </div>
                    <div class="form-group"><label>Valor Actual</label><input type="number" step="0.1" id="indicatorCurrent" /></div>
                </div>
                <div class="form-group">
                    <label>Periodicidad *</label>
                    <div class="period-selector">
                        <div class="type-option" data-period="semanal">📆 Semanal</div>
                        <div class="type-option" data-period="quincenal">📋 Quincenal</div>
                        <div class="type-option" data-period="mensual">📊 Mensual</div>
                    </div>
                    <input type="hidden" id="indicatorPeriod" required />
                </div>
                <div class="form-actions">
                    <button type="button" class="btn-delete-modal" id="deleteBtn" style="display: none;">🗑️ Eliminar</button>
                    <button type="button" class="btn-cancel">Cancelar</button>
                    <button type="submit" class="btn-submit">Guardar</button>
                </div>
            </form>
        </div>
    </div>

    <div id="actionModal" class="modal">
        <div class="modal-content">
            <button class="modal-close" onclick="closeModalById('actionModal')">&times;</button>
            <div class="modal-header">
                <span>Agregar Acción a: <span id="actionIndicatorName"></span></span>
            </div>
            <form id="actionForm">
                <input type="hidden" id="actionIndicatorId" />
                <div class="form-group"><label>Descripción de la Acción *</label><textarea id="actionDescription" rows="3" required></textarea></div>
                <div class="form-row">
                    <div class="form-group"><label>Fecha *</label><input type="date" id="actionDate" required /></div>
                    <div class="form-group">
                        <label>Estado de Evolución *</label>
                        <select id="actionStatus" required>
                            <option value="">-- Seleccionar --</option>
                            <option value="inicio">🔵 En Inicio</option>
                            <option value="mejora">✅ Mejora</option>
                            <option value="nomejora">❌ Sin Mejora</option>
