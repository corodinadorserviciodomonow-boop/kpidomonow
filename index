    <script>
        /* SCRIPT ORIGINAL BASE */
        let indicators = [];
        let actions = [];
        /* NUEVAS VARIABLES COLABORADORES */
        let masterCollaborators = []; // Lista maestra de nombres
        let kpiAssignments = {}; // Asignaciones individuales { kpiId: [{name, target, current}, ...] }
        
        let editingId = null;
        let currentAreaFilter = 'all';
        let currentPeriodFilter = 'all';
        let okrAreaFilter = 'all';
        let okrPeriodFilter = 'all';
        let kpiAreaFilter = 'all';
        let kpiPeriodFilter = 'all';

        // DATOS BASE ORIGINALES EXACTOS
        const OKRsBase = [
            { id: 'okr-1', name: '10 PH en vivo con 80% de módulos', area: 'fabrica', period: 'mensual', target: 10, unit: 'PH', current: 7, type: 'okr' },
            { id: 'okr-2', name: '60% infraestructura TI sistematizada', area: 'fabrica', period: 'mensual', target: 60, unit: '%', current: 60, type: 'okr' },
            { id: 'okr-3', name: '60% pruebas QA automatizadas', area: 'fabrica', period: 'semanal', target: 60, unit: '%', current: 48, type: 'okr' },
            { id: 'okr-4', name: '80% satisfacción software', area: 'fabrica', period: 'mensual', target: 80, unit: '%', current: 0, type: 'okr' },
            { id: 'okr-5', name: 'Equipo capacitado al 90%', area: 'marketing', period: 'mensual', target: 90, unit: '%', current: 90, type: 'okr' },
            { id: 'okr-6', name: '80% material comercial optimizado', area: 'marketing', period: 'mensual', target: 80, unit: '%', current: 72, type: 'okr' },
            { id: 'okr-7', name: 'Plan de mercadeo diseñado al 90%', area: 'marketing', period: 'quincenal', target: 90, unit: '%', current: 85, type: 'okr' },
            { id: 'okr-8', name: 'Equipo Ventas certificado al 90%', area: 'comercial', period: 'mensual', target: 90, unit: '%', current: 85, type: 'okr' },
            { id: 'okr-9', name: '10 socios de negocio reclutados', area: 'comercial', period: 'mensual', target: 10, unit: 'socios', current: 10, type: 'okr' },
            { id: 'okr-10', name: '80% socios capacitados', area: 'comercial', period: 'semanal', target: 80, unit: '%', current: 64, type: 'okr' },
            { id: 'okr-11', name: '20 propiedades cerradas', area: 'comercial', period: 'mensual', target: 20, unit: 'propiedades', current: 16, type: 'okr' },
            { id: 'okr-12', name: 'Equipo Servicio certificado al 90%', area: 'servicio', period: 'mensual', target: 90, unit: '%', current: 88, type: 'okr' },
            { id: 'okr-13', name: '80% PH implementadas con adopción', area: 'servicio', period: 'semanal', target: 80, unit: '%', current: 72, type: 'okr' },
            { id: 'okr-14', name: 'BPO definido y negociado al 90%', area: 'servicio', period: 'mensual', target: 90, unit: '%', current: 85, type: 'okr' }
        ];

        const KPIsBase = [
            { id: 'kpi-1', name: 'Cobertura de módulos funcionales', area: 'fabrica', period: 'semanal', target: 95, unit: '%', current: 92, type: 'kpi' },
            { id: 'kpi-2', name: 'Defectos encontrados en QA', area: 'fabrica', period: 'semanal', target: 5, unit: 'Cantidad', current: 3, type: 'kpi' },
            { id: 'kpi-3', name: 'Ciclo de desarrollo', area: 'fabrica', period: 'semanal', target: 14, unit: 'Días', current: 12, type: 'kpi' },
            { id: 'kpi-4', name: 'Leads generados', area: 'marketing', period: 'quincenal', target: 50, unit: 'Cantidad', current: 45, type: 'kpi' },
            { id: 'kpi-5', name: 'Tasa de apertura', area: 'marketing', period: 'semanal', target: 35, unit: '%', current: 32, type: 'kpi' },
            { id: 'kpi-6', name: 'Pipeline de oportunidades', area: 'comercial', period: 'mensual', target: 500000, unit: 'USD', current: 450000, type: 'kpi' },
            { id: 'kpi-7', name: 'Tasa de cierre', area: 'comercial', period: 'mensual', target: 35, unit: '%', current: 32, type: 'kpi' },
            { id: 'kpi-8', name: 'Ciclo de implementación', area: 'servicio', period: 'semanal', target: 45, unit: 'Días', current: 42, type: 'kpi' },
            { id: 'kpi-9', name: 'Tasa entregas puntual', area: 'servicio', period: 'semanal', target: 90, unit: '%', current: 88, type: 'kpi' }
        ];

        // INICIALIZACIÓN ORIGINAL ACTUALIZADA
        document.addEventListener('DOMContentLoaded', function() {
            loadData();
            initializeNavigation();
            initializeModals();
            initializeFilters();
            /* NUEVA INICIALIZACIÓN COLABORADORES */
            initializeCollabManagement();
            renderAllSections();
        });

        // LÓGICA ORIGINAL DE NAVEGACIÓN, FILTROS Y MODALES
        function initializeNavigation() {
            document.querySelectorAll('.nav-link').forEach(link => {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    const section = this.getAttribute('data-section');
                    document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
                    document.getElementById(section).classList.add('active');
                    document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
                    this.classList.add('active');
                    const titles = { 'home': '📊 Dashboard por Área', 'okrs': '🎯 Objetivos y Resultados Clave', 'kpis': '📈 Indicadores Clave', 'acciones': '⚡ Seguimiento de Acciones' };
                    document.getElementById('pageTitle').textContent = titles[section];
                });
            });
        }

        function initializeFilters() {
            // Home filters
            document.querySelectorAll('[data-filter="area"]').forEach(btn => { btn.addEventListener('click', function() { document.querySelectorAll('[data-filter="area"]').forEach(b => b.classList.remove('active')); this.classList.add('active'); currentAreaFilter = this.getAttribute('data-value'); renderHome(); }); });
            document.querySelectorAll('[data-filter="period"]').forEach(btn => { btn.addEventListener('click', function() { document.querySelectorAll('[data-filter="period"]').forEach(b => b.classList.remove('active')); this.classList.add('active'); currentPeriodFilter = this.getAttribute('data-value'); renderHome(); }); });
            // OKRs filters
            document.querySelectorAll('.okr-area-filter').forEach(btn => { btn.addEventListener('click', function() { document.querySelectorAll('.okr-area-filter').forEach(b => b.classList.remove('active')); this.classList.add('active'); okrAreaFilter = this.getAttribute('data-value'); renderOKRs(); }); });
            document.querySelectorAll('.okr-period-filter').forEach(btn => { btn.addEventListener('click', function() { document.querySelectorAll('.okr-period-filter').forEach(b => b.classList.remove('active')); this.classList.add('active'); okrPeriodFilter = this.getAttribute('data-value'); renderOKRs(); }); });
            // KPIs filters
            document.querySelectorAll('.kpi-area-filter').forEach(btn => { btn.addEventListener('click', function() { document.querySelectorAll('.kpi-area-filter').forEach(b => b.classList.remove('active')); this.classList.add('active'); kpiAreaFilter = this.getAttribute('data-value'); renderKPIs(); }); });
            document.querySelectorAll('.kpi-period-filter').forEach(btn => { btn.addEventListener('click', function() { document.querySelectorAll('.kpi-period-filter').forEach(b => b.classList.remove('active')); this.classList.add('active'); kpiPeriodFilter = this.getAttribute('data-value'); renderKPIs(); }); });
        }

        function initializeModals() {
            document.getElementById('addBtn').addEventListener('click', () => { editingId = null; openIndicatorModal(); });
            document.querySelectorAll('.modal-close, .btn-cancel').forEach(btn => { btn.addEventListener('click', function() { this.closest('.modal').classList.remove('active'); }); });
            document.querySelectorAll('.type-selector .type-option').forEach(option => { option.addEventListener('click', function() { const type = this.getAttribute('data-type'); if (type) { document.querySelectorAll('.type-selector .type-option').forEach(o => o.classList.remove('selected')); this.classList.add('selected'); document.getElementById('indicatorType').value = type; } }); });
            document.querySelectorAll('.period-selector .type-option').forEach(option => { option.addEventListener('click', function() { const period = this.getAttribute('data-period'); if (period) { document.querySelectorAll('.period-selector .type-option').forEach(o => o.classList.remove('selected')); this.classList.add('selected'); document.getElementById('indicatorPeriod').value = period; } }); });
            document.getElementById('indicatorForm').addEventListener('submit', (e) => { e.preventDefault(); saveIndicator(); });
            document.getElementById('deleteBtn').addEventListener('click', () => { if (confirm('¿Confirmas la eliminación?')) { indicators = indicators.filter(i => i.id !== editingId); localStorage.setItem('domonow_indicators', JSON.stringify(indicators)); document.getElementById('indicatorModal').classList.remove('active'); renderAllSections(); } });
            document.getElementById('actionForm').addEventListener('submit', (e) => { e.preventDefault(); saveAction(); });
            window.addEventListener('click', function(e) { if (e.target.classList.contains('modal')) { e.target.classList.remove('active'); } });
        }

        /* LÓGICA ORIGINAL DE INDICADORES Y ACCIONES */
        function openIndicatorModal(indicator = null) {
            editingId = indicator?.id || null;
            const form = document.getElementById('indicatorForm');
            document.querySelectorAll('.type-option').forEach(o => o.classList.remove('selected'));
            if (indicator) {
                document.getElementById('modalTitle').textContent = 'Editar Indicador';
                document.getElementById('deleteBtn').style.display = 'block';
                const typeOpt = document.querySelector(`.type-selector [data-type="${indicator.type}"]`);
                if(typeOpt) typeOpt.classList.add('selected');
                const periodOpt = document.querySelector(`.period-selector [data-period="${indicator.period}"]`);
                if(periodOpt) periodOpt.classList.add('selected');
                document.getElementById('indicatorType').value = indicator.type;
                document.getElementById('indicatorName').value = indicator.name;
                document.getElementById('indicatorArea').value = indicator.area;
                document.getElementById('indicatorTarget').value = indicator.target;
                document.getElementById('indicatorUnit').value = indicator.unit;
                document.getElementById('indicatorCurrent').value = indicator.current || '';
                document.getElementById('indicatorPeriod').value = indicator.period;
            } else {
                document.getElementById('modalTitle').textContent = 'Crear Nuevo Indicador';
                document.getElementById('deleteBtn').style.display = 'none';
                form.reset();
            }
            document.getElementById('indicatorModal').classList.add('active');
        }

        function saveIndicator() {
            const type = document.getElementById('indicatorType').value;
            const period = document.getElementById('indicatorPeriod').value;
            if (!type || !period) { alert('Selecciona tipo y periodicidad'); return; }
            const data = { id: editingId || `custom-${Date.now()}`, type, name: document.getElementById('indicatorName').value, area: document.getElementById('indicatorArea').value, target: parseFloat(document.getElementById('indicatorTarget').value), unit: document.getElementById('indicatorUnit').value, current: parseFloat(document.getElementById('indicatorCurrent').value) || 0, period };
            
            if (editingId) { 
                // CORRECIÓN: Buscar en todos los arrays (OKRsBase, KPIsBase, indicators)
                let found = false;
                
                // Buscar en OKRsBase
                let index = OKRsBase.findIndex(i => i.id === editingId);
                if (index !== -1) {
                    OKRsBase[index] = data;
                    localStorage.setItem('domonow_okrs', JSON.stringify(OKRsBase));
                    found = true;
                }
                
                // Buscar en KPIsBase
                if (!found) {
                    index = KPIsBase.findIndex(i => i.id === editingId);
                    if (index !== -1) {
                        KPIsBase[index] = data;
                        localStorage.setItem('domonow_kpis', JSON.stringify(KPIsBase));
                        found = true;
                    }
                }
                
                // Buscar en indicators (personalizados)
                if (!found) {
                    index = indicators.findIndex(i => i.id === editingId);
                    if (index !== -1) {
                        indicators[index] = data;
                        localStorage.setItem('domonow_indicators', JSON.stringify(indicators));
                        found = true;
                    }
                }
                
                if (!found) {
                    alert('⚠️ No se encontró el indicador para actualizar');
                    return;
                }
            } else { 
                indicators.push(data);
                localStorage.setItem('domonow_indicators', JSON.stringify(indicators));
            }
            
            document.getElementById('indicatorModal').classList.remove('active');
            renderAllSections();
            alert('✅ Indicador actualizado exitosamente');
        }

        function openActionModal(indicatorId, indicatorName) {
            document.getElementById('actionIndicatorId').value = indicatorId;
            document.getElementById('actionIndicatorName').textContent = indicatorName;
            document.getElementById('actionDate').valueAsDate = new Date();
            document.getElementById('actionForm').reset();
            document.getElementById('actionModal').classList.add('active');
        }

        function saveAction() {
            const indicatorId = document.getElementById('actionIndicatorId').value;
            const description = document.getElementById('actionDescription').value.trim();
            const date = document.getElementById('actionDate').value;
            const status = document.getElementById('actionStatus').value;
            const responsible = document.getElementById('actionResponsible').value.trim();
            
            // Validaciones
            if (!indicatorId) {
                alert('⚠️ Falta el indicador. Por favor recarga la página.');
                return;
            }
            if (!description) {
                alert('⚠️ La descripción de la acción es obligatoria');
                return;
            }
            if (!date) {
                alert('⚠️ La fecha es obligatoria');
                return;
            }
            if (!status) {
                alert('⚠️ Debes seleccionar un estado de evolución');
                return;
            }
            
            // Crear la acción con todos los campos necesarios
            const action = { 
                id: Date.now(), 
                indicatorId: indicatorId, 
                title: description,  // Agregar title para compatibilidad
                description: description, 
                date: date, 
                status: status, 
                responsible: responsible || 'No asignado'
            };
            
            actions.push(action);
            localStorage.setItem('domonow_actions', JSON.stringify(actions));
            document.getElementById('actionModal').classList.remove('active');
            document.getElementById('actionForm').reset();
            renderAllSections();
            alert('✅ Acción registrada exitosamente');
        }

        /* LÓGICA ORIGINAL DE RENDERIZADO Y FILTROS */
        function renderAllSections() { renderHome(); renderOKRs(); renderKPIs(); renderAcciones(); }
        function getFilteredIndicators(type = null, areaFilter = 'all', periodFilter = 'all') { const allIndicators = [ ...OKRsBase.map(o => ({ ...o, isBase: true })), ...KPIsBase.map(k => ({ ...k, isBase: true })), ...indicators ]; return allIndicators.filter(ind => { if (type && ind.type !== type) return false; if (areaFilter !== 'all' && ind.area !== areaFilter) return false; if (periodFilter !== 'all' && ind.period !== periodFilter) return false; return true; }); }
        function renderHome() { const filtered = getFilteredIndicators(null, currentAreaFilter, currentPeriodFilter); const okrs = filtered.filter(i => i.type === 'okr'); const kpis = filtered.filter(i => i.type === 'kpi'); let html = ''; if (okrs.length > 0) { html += `<h3 style="margin-top: 24px; margin-bottom: 16px; color: var(--okr-color); font-size: 16px;">🎯 OKRs (${okrs.length})</h3>`; okrs.forEach(ind => html += renderIndicatorCard(ind)); } if (kpis.length > 0) { html += `<h3 style="margin-top: 24px; margin-bottom: 16px; color: var(--kpi-color); font-size: 16px;">📈 KPIs (${kpis.length})</h3>`; kpis.forEach(ind => html += renderIndicatorCard(ind)); } if (filtered.length === 0) { html = '<div class="empty-state">No hay indicadores para esta vista</div>'; } document.getElementById('homeContent').innerHTML = html; attachIndicatorEvents(); }
        function renderOKRs() { const filtered = getFilteredIndicators('okr', okrAreaFilter, okrPeriodFilter); let html = ''; if (filtered.length === 0) { html = '<div class="empty-state">No hay OKRs para esta vista</div>'; } else { filtered.forEach(ind => html += renderIndicatorCard(ind)); } document.getElementById('okrsContent').innerHTML = html; attachIndicatorEvents(); }
        function renderKPIs() { const filtered = getFilteredIndicators('kpi', kpiAreaFilter, kpiPeriodFilter); let html = ''; if (filtered.length === 0) { html = '<div class="empty-state">No hay KPIs para esta vista</div>'; } else { filtered.forEach(ind => html += renderIndicatorCard(ind)); } document.getElementById('kpisContent').innerHTML = html; attachIndicatorEvents(); }
        function renderAcciones() { 
            if (actions.length === 0) { 
                document.getElementById('accionesContent').innerHTML = '<div class="empty-state">No hay acciones registradas</div>'; 
                return; 
            } 
            let html = `<div class="card">
                <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
                    <thead style="text-align: left; color: var(--text-secondary);">
                        <tr>
                            <th style="padding: 10px; border-bottom: 2px solid var(--border-color);">Indicador</th>
                            <th style="padding: 10px; border-bottom: 2px solid var(--border-color);">Descripción</th>
                            <th style="padding: 10px; border-bottom: 2px solid var(--border-color);">Responsable</th>
                            <th style="padding: 10px; border-bottom: 2px solid var(--border-color);">Fecha</th>
                            <th style="padding: 10px; border-bottom: 2px solid var(--border-color);">Estado</th>
                            <th style="padding: 10px; border-bottom: 2px solid var(--border-color); text-align: center;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>`; 
            actions.forEach(action => { 
                const statusEmoji = action.status === 'mejora' ? '✅' : action.status === 'inicio' ? '🔵' : '❌'; 
                html += `<tr style="border-bottom: 1px solid var(--border-color);">
                    <td style="padding: 10px;">${action.indicatorId}</td>
                    <td style="padding: 10px;">${action.description || 'Sin descripción'}</td>
                    <td style="padding: 10px;">${action.responsible || 'No asignado'}</td>
                    <td style="padding: 10px;">${action.date ? new Date(action.date).toLocaleDateString('es-CO') : 'Sin fecha'}</td>
                    <td style="padding: 10px;">${statusEmoji} ${action.status || 'Pendiente'}</td>
                    <td style="padding: 10px; text-align: center;">
                        <button class="btn-table-action view-action-table-btn" data-id="${action.id}" title="Ver acción" style="background: var(--info-color); color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; font-size: 11px; margin-right: 4px;">👁️ Ver</button>
                        <button class="btn-table-action edit-action-table-btn" data-id="${action.id}" title="Editar acción" style="background: var(--primary-color); color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; font-size: 11px; margin-right: 4px;">✏️ Editar</button>
                        <button class="btn-table-action delete-action-table-btn" data-id="${action.id}" title="Eliminar acción" style="background: var(--danger-color); color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; font-size: 11px;">🗑️ Eliminar</button>
                    </td>
                </tr>`; 
            }); 
            html += '</tbody></table></div>'; 
            document.getElementById('accionesContent').innerHTML = html;
            
            // Agregar event listeners a los botones de la tabla
            attachActionTableEvents();
        }

        function attachActionTableEvents() {
            // Ver acción desde tabla
            document.querySelectorAll('.view-action-table-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const actionId = parseInt(this.getAttribute('data-id'));
                    const action = actions.find(a => parseInt(a.id) === actionId);
                    if(action) {
                        showActionDetails(action);
                    }
                });
            });

            // Editar acción desde tabla
            document.querySelectorAll('.edit-action-table-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const actionId = parseInt(this.getAttribute('data-id'));
                    const action = actions.find(a => parseInt(a.id) === actionId);
                    if(action) {
                        openActionEditModal(action);
                    }
                });
            });

            // Eliminar acción desde tabla
            document.querySelectorAll('.delete-action-table-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const actionId = parseInt(this.getAttribute('data-id'));
                    deleteActionFromTable(actionId);
                });
            });
        }

        function deleteActionFromTable(actionId) {
            if(confirm('¿Estás seguro de que deseas eliminar esta acción?')) {
                actionId = parseInt(actionId);
                actions = actions.filter(a => parseInt(a.id) !== actionId);
                localStorage.setItem('domonow_actions', JSON.stringify(actions));
                renderAllSections();
                alert('✅ Acción eliminada');
            }
        }

        // Carga de Datos Original
        function loadData() {
            const saved = localStorage.getItem('domonow_indicators');
            const savedActions = localStorage.getItem('domonow_actions');
            if (saved) indicators = JSON.parse(saved);
            if (savedActions) actions = JSON.parse(savedActions);
            
            /* CARGA DE DATOS COLABORADORES */
            const savedMaster = localStorage.getItem('domonow_masterCollabs');
            const savedAssigns = localStorage.getItem('domonow_kpiAssigns');
            if(savedMaster) masterCollaborators = JSON.parse(savedMaster);
            if(savedAssigns) kpiAssignments = JSON.parse(savedAssigns);
        }

        /* ************************************************************ */
        /* NUEVA LÓGICA: GESTIÓN DE COLABORADORES Y METAS INDIVIDUALES */
        /* ************************************************************ */

        function initializeCollabManagement() {
            // Botón principal de la cabecera
            document.getElementById('manageCollabsBtn').addEventListener('click', openMasterCollabModal);
            
            // Formulario lista maestra
            document.getElementById('masterCollabForm').addEventListener('submit', function(e) {
                e.preventDefault();
                const name = document.getElementById('newCollabName').value.trim();
                if(name && !masterCollaborators.includes(name)) {
                    masterCollaborators.push(name);
                    localStorage.setItem('domonow_masterCollabs', JSON.stringify(masterCollaborators));
                    document.getElementById('newCollabName').value = '';
                    renderMasterCollabList();
                } else if(masterCollaborators.includes(name)) {
                    alert('Este colaborador ya existe.');
                }
            });

            // Formulario asignar meta individual a KPI
            document.getElementById('kpiAssignForm').addEventListener('submit', function(e) {
                e.preventDefault();
                saveKpiAssignment();
            });
        }

        // Modal 1: Lista Maestra
        function openMasterCollabModal() {
            renderMasterCollabList();
            document.getElementById('masterCollabModal').classList.add('active');
        }

        function renderMasterCollabList() {
            const list = document.getElementById('masterCollabList');
            if(masterCollaborators.length === 0) {
                list.innerHTML = '<div style="padding: 15px; text-align:center; color: var(--text-tertiary); font-size: 12px;">No hay colaboradores registrados.</div>';
                return;
            }
            let html = '';
            masterCollaborators.forEach((name, index) => {
                html += `
                    <div class="master-collab-item">
                        <span>${name}</span>
                        <button class="btn-icon delete" onclick="deleteMasterCollab(${index})" title="Eliminar de la lista">✕</button>
                    </div>
                `;
            });
            list.innerHTML = html;
        }

        function deleteMasterCollab(index) {
            if(confirm('¿Eliminar este colaborador de la lista maestra? No se borrarán sus asignaciones existentes en KPIs.')) {
                masterCollaborators.splice(index, 1);
                localStorage.setItem('domonow_masterCollabs', JSON.stringify(masterCollaborators));
                renderMasterCollabList();
            }
        }

        // Modal 2: Asignar a KPI específico
        function openKpiAssignModal(kpiId, kpiName, collabEditIndex = null) {
            document.getElementById('assignKpiId').value = kpiId;
            document.getElementById('assignEditIndex').value = collabEditIndex !== null ? collabEditIndex : '';
            document.getElementById('kpiAssignTitle').textContent = collabEditIndex !== null ? `Editar Meta Individual` : `Asignar a: ${kpiName}`;
            document.getElementById('btnAssignSubmit').textContent = collabEditIndex !== null ? `Actualizar` : `Asignar`;

            // Llenar selector de colaboradores desde lista maestra
            const select = document.getElementById('assignCollabSelect');
            select.innerHTML = '<option value="">-- Seleccionar --</option>';
            masterCollaborators.forEach(name => {
                select.innerHTML += `<option value="${name}">${name}</option>`;
            });

            const form = document.getElementById('kpiAssignForm');
            form.reset();

            // Modo edición
            if(collabEditIndex !== null) {
                const assignment = kpiAssignments[kpiId][collabEditIndex];
                document.getElementById('assignCollabSelect').value = assignment.name;
                // Deshabilitar selector en edición para no cambiar la persona
                document.getElementById('assignCollabSelect').disabled = true; 
                document.getElementById('assignTarget').value = assignment.target;
                document.getElementById('assignCurrent').value = assignment.current || '';
            } else {
                document.getElementById('assignCollabSelect').disabled = false;
            }

            document.getElementById('kpiAssignModal').classList.add('active');
        }

        function saveKpiAssignment() {
            const kpiId = document.getElementById('assignKpiId').value;
            const editIndex = document.getElementById('assignEditIndex').value;
            
            const assignmentData = {
                name: document.getElementById('assignCollabSelect').value,
                target: parseFloat(document.getElementById('assignTarget').value),
                current: parseFloat(document.getElementById('assignCurrent').value) || 0
            };

            if(!assignmentData.name) { alert('Selecciona un colaborador.'); return; }

            if(!kpiAssignments[kpiId]) kpiAssignments[kpiId] = [];

            if(editIndex !== '') {
                // Actualizar existente
                kpiAssignments[kpiId][editIndex] = assignmentData;
            } else {
                // Verificar si ya está asignado
                const exists = kpiAssignments[kpiId].some(a => a.name === assignmentData.name);
                if(exists) {
                    alert('Este colaborador ya está asignado a este KPI. Edita su registro si necesitas cambiar las metas.');
                    return;
                }
                // Añadir nuevo
                kpiAssignments[kpiId].push(assignmentData);
            }

            localStorage.setItem('domonow_kpiAssigns', JSON.stringify(kpiAssignments));
            closeModalById('kpiAssignModal');
            renderAllSections(); // Recargar vistas
        }

        function deleteKpiAssignment(kpiId, index) {
            if(confirm('¿Eliminar esta asignación individual?')) {
                kpiAssignments[kpiId].splice(index, 1);
                localStorage.setItem('domonow_kpiAssigns', JSON.stringify(kpiAssignments));
                renderAllSections();
            }
        }

        /* ************************************************************ */
        /* MODIFICACIÓN DE RENDERIZADO PARA INCLUIR COLABORADORES EN KPI */
        /* ************************************************************ */

        function renderIndicatorCard(indicator) {
            const pct = Math.min((indicator.current / indicator.target) * 100, 100);
            const color = indicator.type === 'okr' ? '#8B5CF6' : '#06A77D';
            
            // Sección base de la tarjeta (común para OKR y KPI)
            let cardHtml = `
                <div class="indicator-card" data-id="${indicator.id}">
                    <div class="indicator-header">
                        <div>
                            <div class="indicator-badges">
                                <span class="badge ${indicator.type}">${indicator.type.toUpperCase()}</span>
                                <span class="badge period">${indicator.period}</span>
                            </div>
                            <div class="indicator-title">${indicator.name}</div>
                            <div class="indicator-meta">${indicator.current}/${indicator.target} ${indicator.unit}</div>
                        </div>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: ${pct}%; background: ${color};"></div>
                    </div>
                    <div class="progress-text">${Math.round(pct)}% de progreso</div>
            `;

            // NUEVA LÓGICA: INSERTAR SECCIÓN DE COLABORADORES INDIVIDUALES SOLO SI ES KPI
            if(indicator.type === 'kpi') {
                const assigns = kpiAssignments[indicator.id] || [];
                cardHtml += `
                    <div class="kpi-collabs-section">
                        <div class="kpi-collabs-header">
                            <span class="kpi-collabs-title">👤 Desempeño Individual</span>
                            <button class="btn-small info assign-collab-btn" 
                                    style="padding: 4px 8px; font-size: 11px;"
                                    data-id="${indicator.id}" 
                                    data-name="${indicator.name}"
                                    title="Asignar colaborador con meta individual a este KPI">
                                + Asignar
                            </button>
                        </div>
                        <div class="kpi-collabs-list">
                            ${assigns.length === 0 ? 
                                `<div style="font-size: 11px; color: var(--text-tertiary); text-align:center; padding: 5px;">Sin asignaciones individuales</div>` 
                                : 
                                assigns.map((assign, index) => {
                                    const indivPct = assign.target > 0 ? Math.round((assign.current / assign.target) * 100) : 0;
                                    return `
                                        <div class="collab-individual-card">
                                            <div class="collab-indiv-info">
                                                <div class="collab-indiv-name">${assign.name}</div>
                                                <div class="collab-indiv-meta">${assign.current} / ${assign.target}</div>
                                            </div>
                                            <div class="collab-indiv-performance">
                                                <span class="collab-indiv-pct">${indivPct}%</span>
                                                <div style="display:flex; flex-direction:column; gap:2px">
                                                    <button class="btn-icon edit-indiv-btn" 
                                                            data-kpiid="${indicator.id}" 
                                                            data-kpiname="${indicator.name}"
                                                            data-index="${index}" title="Editar meta/resultado">✏️</button>
                                                    <button class="btn-icon delete delete-indiv-btn" 
                                                            data-kpiid="${indicator.id}" 
                                                            data-index="${index}" title="Eliminar asignación">✕</button>
                                                </div>
                                            </div>
                                        </div>
                                    `;
                                }).join('')
                            }
                        </div>
                    </div>
                `;
            }

            // NUEVA SECCIÓN: ACCIONES RELACIONADAS CON RESPONSABLE VISIBLE
            const relatedActions = actions.filter(action => action.indicatorId === indicator.id);
            if(relatedActions.length > 0) {
                cardHtml += `
                    <div class="actions-section">
                        <div class="actions-header">
                            <span class="actions-title">⚡ Acciones (${relatedActions.length})</span>
                        </div>
                        <div class="actions-list">
                            ${relatedActions.map((action, index) => `
                                <div class="action-item-card">
                                    <div class="action-item-info">
                                        <div class="action-item-title">${action.title}</div>
                                        <div class="action-item-meta">Fecha: ${action.date || 'Sin fecha'}</div>
                                        <div class="action-item-responsible">👤 Responsable: ${action.responsible || 'No asignado'}</div>
                                    </div>
                                    <div class="action-item-actions">
                                        <button class="btn-icon-action view-action-btn" 
                                                data-id="${action.id}" 
                                                title="Ver acción">👁️ Ver</button>
                                        <button class="btn-icon-action edit-action-btn" 
                                                data-id="${action.id}" 
                                                title="Editar acción">✏️ Editar</button>
                                    </div>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                `;
            }

            // Acciones de pie de tarjeta (comunes)
            cardHtml += `
                    <div class="indicator-actions">
                        <button class="btn-small btn-edit" data-id="${indicator.id}">✏️ Editar</button>
                        <button class="btn-small btn-action" data-id="${indicator.id}">⚡ Agregar Acción</button>
                    </div>
                </div>
            `;
            return cardHtml;
        }

        // Actualización de attachEvents Original para incluir los nuevos botones
        function attachIndicatorEvents() {
            // Eventos originales
            document.querySelectorAll('.btn-edit').forEach(btn => { btn.addEventListener('click', function() { const id = this.getAttribute('data-id'); const indicator = [ ...OKRsBase, ...KPIsBase, ...indicators ].find(i => i.id === id); if (indicator) openIndicatorModal(indicator); }); });
            document.querySelectorAll('.btn-action').forEach(btn => { btn.addEventListener('click', function() { const id = this.getAttribute('data-id'); const indicator = [ ...OKRsBase, ...KPIsBase, ...indicators ].find(i => i.id === id); if (indicator) openActionModal(id, indicator.name); }); });

            // NUEVOS EVENTOS COLABORADORES INDIVIDUALES
            // Botón + Asignar en cabecera de sección individual
            document.querySelectorAll('.assign-collab-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    if(masterCollaborators.length === 0) {
                        alert('Primero debes agregar colaboradores en la lista maestra (botón 👥 Colaboradores en la parte superior).');
                        return;
                    }
                    const id = this.getAttribute('data-id');
                    const name = this.getAttribute('data-name');
                    openKpiAssignModal(id, name);
                });
            });

            // Botón editar individual (lapiz)
            document.querySelectorAll('.edit-indiv-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const kpiId = this.getAttribute('data-kpiid');
                    const kpiName = this.getAttribute('data-kpiname');
                    const index = this.getAttribute('data-index');
                    openKpiAssignModal(kpiId, kpiName, index);
                });
            });

            // Botón eliminar individual (X)
            document.querySelectorAll('.delete-indiv-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const kpiId = this.getAttribute('data-kpiid');
                    const index = this.getAttribute('data-index');
                    deleteKpiAssignment(kpiId, index);
                });
            });

            // NUEVOS EVENTOS PARA ACCIONES
            // Botón ver acción
            document.querySelectorAll('.view-action-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const actionId = this.getAttribute('data-id');
                    const action = actions.find(a => a.id === actionId);
                    if(action) {
                        showActionDetails(action);
                    }
                });
            });

            // Botón editar acción
            document.querySelectorAll('.edit-action-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const actionId = this.getAttribute('data-id');
                    const action = actions.find(a => a.id === actionId);
                    if(action) {
                        openActionEditModal(action);
                    }
                });
            });
        }

        // Helper para cerrar modales específicos
        function closeModalById(id) {
            document.getElementById(id).classList.remove('active');
        }

        // NUEVAS FUNCIONES PARA ACCIONES
        // Mostrar detalles de una acción en un modal read-only
        function showActionDetails(action) {
            const modalContent = document.querySelector('#actionModal .modal-content');
            const indicator = [ ...OKRsBase, ...KPIsBase, ...indicators ].find(i => i.id === action.indicatorId);
            const indicatorName = indicator ? indicator.name : 'Sin indicador';
            
            modalContent.innerHTML = `
                <button class="modal-close" onclick="closeModalById('actionModal')">×</button>
                <div class="modal-header">
                    <span>📋 Detalles de la Acción - ${indicatorName}</span>
                </div>
                <div class="form-group">
                    <label>Acción</label>
                    <div style="padding: 10px 12px; background: var(--bg-light); border-radius: 6px; border: 1px solid var(--border-color); color: var(--text-primary);">${action.title || action.description || 'Sin descripción'}</div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Responsable</label>
                        <div style="padding: 10px 12px; background: var(--bg-light); border-radius: 6px; border: 1px solid var(--border-color); color: var(--text-primary);">${action.responsible || 'No asignado'}</div>
                    </div>
                    <div class="form-group">
                        <label>Fecha Límite</label>
                        <div style="padding: 10px 12px; background: var(--bg-light); border-radius: 6px; border: 1px solid var(--border-color); color: var(--text-primary);">${action.date || 'Sin fecha'}</div>
                    </div>
                </div>
                <div class="form-group">
                    <label>KPI Relacionado</label>
                    <div style="padding: 10px 12px; background: var(--bg-light); border-radius: 6px; border: 1px solid var(--border-color); color: var(--text-primary); font-weight: 600;">${indicatorName}</div>
                </div>
                <div class="form-group">
                    <label>Estado</label>
                    <div style="padding: 10px 12px; background: var(--bg-light); border-radius: 6px; border: 1px solid var(--border-color); color: var(--text-primary);">${action.status || 'Pendiente'}</div>
                </div>
                <div style="display: flex; gap: 12px; margin-top: 24px;">
                    <button class="action-btn" onclick="editActionFromDetails('${action.id}')" type="button">✏️ Editar Acción</button>
                    <button class="action-btn" style="background: var(--text-secondary);" onclick="closeModalById('actionModal')" type="button">Cerrar</button>
                </div>
            `;
            document.getElementById('actionModal').classList.add('active');
        }

        // Función para pasar de detalles a edición
        function editActionFromDetails(actionId) {
            actionId = parseInt(actionId);
            const action = actions.find(a => parseInt(a.id) === actionId);
            if(action) {
                openActionEditModal(action);
            }
        }

        // Modal para editar acción (similar a como se editan colaboradores)
        function openActionEditModal(action) {
            const indicator = [ ...OKRsBase, ...KPIsBase, ...indicators ].find(i => i.id === action.indicatorId);
            const modalContent = document.querySelector('#actionModal .modal-content');
            const indicatorName = indicator ? indicator.name : 'Sin indicador';
            
            modalContent.innerHTML = `
                <button class="modal-close" onclick="closeModalById('actionModal')">×</button>
                <div class="modal-header">
                    <span>✏️ Editar Acción - ${indicatorName}</span>
                </div>
                <div class="form-group">
                    <label>Acción *</label>
                    <input type="text" id="editActionTitle" value="${action.title || action.description || ''}" placeholder="Descripción de la acción">
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Responsable</label>
                        <select id="editActionResponsible">
                            <option value="">Seleccionar responsable</option>
                            ${masterCollaborators.map(c => `<option value="${c}" ${action.responsible === c ? 'selected' : ''}>${c}</option>`).join('')}
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Fecha Límite</label>
                        <input type="date" id="editActionDate" value="${action.date || ''}">
                    </div>
                </div>
                <div class="form-group">
                    <label>Estado</label>
                    <select id="editActionStatus">
                        <option value="mejora" ${action.status === 'mejora' ? 'selected' : ''}>✅ Mejora</option>
                        <option value="inicio" ${action.status === 'inicio' ? 'selected' : ''}>🔵 Inicio</option>
                        <option value="no-logrado" ${action.status === 'no-logrado' ? 'selected' : ''}>❌ No Logrado</option>
                        <option value="Pendiente" ${action.status === 'Pendiente' ? 'selected' : ''}>Pendiente</option>
                        <option value="En Progreso" ${action.status === 'En Progreso' ? 'selected' : ''}>En Progreso</option>
                        <option value="Completada" ${action.status === 'Completada' ? 'selected' : ''}>Completada</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>KPI Relacionado</label>
                    <div style="padding: 10px 12px; background: var(--bg-light); border-radius: 6px; border: 1px solid var(--border-color); color: var(--text-primary); font-weight: 600;">${indicatorName}</div>
                </div>
                <div style="display: flex; gap: 12px; margin-top: 24px;">
                    <button class="action-btn success" onclick="saveActionEdit('${action.id}')" type="button">💾 Guardar Cambios</button>
                    <button class="action-btn" style="background: var(--danger-color);" onclick="deleteAction('${action.id}')" type="button">🗑️ Eliminar Acción</button>
                    <button class="action-btn" style="background: var(--text-secondary);" onclick="closeModalById('actionModal')" type="button">Cancelar</button>
                </div>
            `;
            document.getElementById('actionModal').classList.add('active');
        }

        // Guardar cambios en acción
        function saveActionEdit(actionId) {
            // Convertir a número para comparación correcta
            actionId = parseInt(actionId);
            const actionIndex = actions.findIndex(a => parseInt(a.id) === actionId);
            
            if(actionIndex !== -1) {
                const titleValue = document.getElementById('editActionTitle').value.trim();
                
                if(titleValue === '') {
                    alert('El título de la acción no puede estar vacío');
                    return;
                }
                
                actions[actionIndex].title = titleValue;
                actions[actionIndex].description = titleValue; // Sincronizar con description
                actions[actionIndex].responsible = document.getElementById('editActionResponsible').value;
                actions[actionIndex].date = document.getElementById('editActionDate').value;
                actions[actionIndex].status = document.getElementById('editActionStatus').value;
                
                // Guardar en localStorage
                localStorage.setItem('domonow_actions', JSON.stringify(actions));
                
                closeModalById('actionModal');
                renderAllSections();
                alert('✅ Acción actualizada exitosamente');
            } else {
                alert('⚠️ No se encontró la acción para actualizar');
            }
        }

        // Eliminar acción
        function deleteAction(actionId) {
            if(confirm('¿Estás seguro de que deseas eliminar esta acción?')) {
                actionId = parseInt(actionId);
                actions = actions.filter(a => parseInt(a.id) !== actionId);
                localStorage.setItem('domonow_actions', JSON.stringify(actions));
                closeModalById('actionModal');
                renderAllSections();
                alert('✅ Acción eliminada');
            }
        }
    </script>
</body>
</html>
